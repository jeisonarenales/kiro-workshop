<mxfile host="app.diagrams.net" agent="Kiro CLI" version="24.0.0">
  <diagram id="sudoku-aws-architecture" name="Sudoku AWS Architecture">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0" background="none">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ============ Title ============ -->
        <mxCell id="title" value="Sudoku App — AWS Infrastructure (Terraform)" style="text;html=1;fontSize=20;fontStyle=1;align=left;verticalAlign=middle;fontColor=#232F3D;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="600" height="30" as="geometry" />
        </mxCell>

        <!-- ============ Terraform managed-by group boundary ============ -->
        <mxCell id="tfGroup" value="Managed by Terraform (terraform/ configuration)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;fontSize=13;fontStyle=1;fontColor=#5C4EE5;strokeColor=#5C4EE5;dashed=1;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="120" width="900" height="560" as="geometry" />
        </mxCell>

        <!-- Terraform generic icon+label (no official drawio Terraform stencil exists; using brand-colored generic shape per instructions) -->
        <mxCell id="terraformIcon" value="Terraform" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5C4EE5;fontColor=#FFFFFF;strokeColor=#4B3FC0;fontSize=12;fontStyle=1;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- ============ User / Internet ============ -->
        <mxCell id="user" value="User" style="sketch=0;outlineConnect=0;fontColor=#232F3D;gradientColor=none;fillColor=#232F3D;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.user;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="internet" value="HTTPS" style="sketch=0;outlineConnect=0;fontColor=#232F3D;gradientColor=none;fillColor=#232F3D;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.internet_alt1;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- ============ CloudFront ============ -->
        <mxCell id="cloudfront" value="Amazon CloudFront&#10;Distribution&#10;(aws_cloudfront_distribution.site)" style="sketch=0;outlineConnect=0;fontColor=#232F3D;gradientColor=none;fillColor=#8C4FFF;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudfront;" vertex="1" parent="tfGroup">
          <mxGeometry x="60" y="80" width="78" height="78" as="geometry" />
        </mxCell>

        <!-- OAC -->
        <mxCell id="oac" value="Origin Access Control (OAC)&#10;(aws_cloudfront_origin_access_control.site)" style="sketch=0;outlineConnect=0;fontColor=#232F3D;gradientColor=none;fillColor=#DD344C;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ssl_padlock;" vertex="1" parent="tfGroup">
          <mxGeometry x="260" y="90" width="56" height="56" as="geometry" />
        </mxCell>

        <!-- ============ S3 Bucket ============ -->
        <mxCell id="s3bucket" value="Amazon S3 (Private Bucket)&#10;(aws_s3_bucket.site)&#10;Public access fully blocked" style="sketch=0;outlineConnect=0;fontColor=#232F3D;gradientColor=none;fillColor=#7AA116;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;" vertex="1" parent="tfGroup">
          <mxGeometry x="480" y="80" width="78" height="78" as="geometry" />
        </mxCell>

        <!-- Bucket policy -->
        <mxCell id="bucketPolicy" value="Bucket Policy&#10;(aws_s3_bucket_policy.site)&#10;Allows CloudFront SourceArn only" style="sketch=0;outlineConnect=0;fontColor=#232F3D;gradientColor=none;fillColor=#DD344C;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.policy;" vertex="1" parent="tfGroup">
          <mxGeometry x="480" y="230" width="56" height="56" as="geometry" />
        </mxCell>

        <!-- Bucket contents: objects -->
        <mxCell id="s3ObjectsHtml" value="sudoku.html&#10;(aws_s3_object.sudoku_html)" style="sketch=0;outlineConnect=0;fontColor=#232F3D;gradientColor=none;fillColor=#7AA116;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.document;" vertex="1" parent="tfGroup">
          <mxGeometry x="640" y="70" width="50" height="50" as="geometry" />
        </mxCell>

        <mxCell id="s3ObjectsJs" value="js/*.js (8 files)&#10;(aws_s3_object.js_files, for_each)" style="sketch=0;outlineConnect=0;fontColor=#232F3D;gradientColor=none;fillColor=#7AA116;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.documents;" vertex="1" parent="tfGroup">
          <mxGeometry x="750" y="70" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- Bucket-level configuration group -->
        <mxCell id="bucketConfigGroup" value="Bucket configuration" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;fontSize=11;fontStyle=1;fontColor=#7AA116;strokeColor=#7AA116;dashed=1;fillColor=none;" vertex="1" parent="tfGroup">
          <mxGeometry x="460" y="330" width="360" height="170" as="geometry" />
        </mxCell>

        <mxCell id="publicAccessBlock" value="Public Access Block&#10;(aws_s3_bucket_public_access_block)&#10;All public access blocked" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2F8E9;strokeColor=#7AA116;fontSize=10;align=center;" vertex="1" parent="tfGroup">
          <mxGeometry x="470" y="350" width="160" height="55" as="geometry" />
        </mxCell>

        <mxCell id="ownershipControls" value="Ownership Controls&#10;(aws_s3_bucket_ownership_controls)&#10;BucketOwnerEnforced" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2F8E9;strokeColor=#7AA116;fontSize=10;align=center;" vertex="1" parent="tfGroup">
          <mxGeometry x="645" y="350" width="160" height="55" as="geometry" />
        </mxCell>

        <mxCell id="encryption" value="Server-Side Encryption&#10;(aws_s3_bucket_server_side_encryption_configuration)&#10;SSE-S3 (AES256)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2F8E9;strokeColor=#7AA116;fontSize=10;align=center;" vertex="1" parent="tfGroup">
          <mxGeometry x="470" y="415" width="160" height="55" as="geometry" />
        </mxCell>

        <mxCell id="versioning" value="Versioning&#10;(aws_s3_bucket_versioning)&#10;Enabled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2F8E9;strokeColor=#7AA116;fontSize=10;align=center;" vertex="1" parent="tfGroup">
          <mxGeometry x="645" y="415" width="160" height="55" as="geometry" />
        </mxCell>

        <!-- IAM policy document (data source) -->
        <mxCell id="iamPolicyDoc" value="IAM Policy Document (data source)&#10;(data.aws_iam_policy_document.cloudfront_oac_access)&#10;s3:GetObject scoped to CloudFront SourceArn" style="sketch=0;outlineConnect=0;fontColor=#232F3D;gradientColor=none;fillColor=#DD344C;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.identity_and_access_management;" vertex="1" parent="tfGroup">
          <mxGeometry x="280" y="230" width="56" height="56" as="geometry" />
        </mxCell>

        <!-- Random suffix -->
        <mxCell id="randomId" value="Terraform" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5C4EE5;fontColor=#FFFFFF;strokeColor=#4B3FC0;fontSize=10;align=center;arcSize=25;" vertex="1" parent="tfGroup">
          <mxGeometry x="60" y="330" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="randomIdLabel" value="random_id.bucket_suffix&#10;Generates unique bucket name suffix" style="text;html=1;fontSize=10;align=center;verticalAlign=top;fontColor=#232F3D;" vertex="1" parent="tfGroup">
          <mxGeometry x="60" y="392" width="180" height="30" as="geometry" />
        </mxCell>

        <!-- ============ Edges ============ -->

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#232F3D;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="user" target="internet">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e2" value="GET /sudoku.html" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#232F3D;strokeWidth=2;fontSize=11;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="internet" target="cloudfront">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e3" value="Signed request&#10;(SigV4)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#8C4FFF;strokeWidth=2;fontSize=10;dashed=1;" edge="1" parent="tfGroup" source="cloudfront" target="oac">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e4" value="s3:GetObject" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#8C4FFF;strokeWidth=2;fontSize=10;" edge="1" parent="tfGroup" source="oac" target="s3bucket">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e5" value="grants access via" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#DD344C;strokeWidth=1.5;fontSize=9;dashed=1;" edge="1" parent="tfGroup" source="bucketPolicy" target="s3bucket">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e6" value="defines" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#DD344C;strokeWidth=1.5;fontSize=9;dashed=1;" edge="1" parent="tfGroup" source="iamPolicyDoc" target="bucketPolicy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#7AA116;strokeWidth=1.5;fontSize=9;" edge="1" parent="tfGroup" source="s3bucket" target="s3ObjectsHtml">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#7AA116;strokeWidth=1.5;fontSize=9;" edge="1" parent="tfGroup" source="s3bucket" target="s3ObjectsJs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#7AA116;strokeWidth=1;dashed=1;" edge="1" parent="tfGroup" source="randomId" target="s3bucket">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============ Legend ============ -->
        <mxCell id="legendBox" value="Legend" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;fontSize=12;fontStyle=1;strokeColor=#B0B0B0;fillColor=none;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="1140" y="120" width="220" height="200" as="geometry" />
        </mxCell>

        <mxCell id="legendAws" value="AWS Resource" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8C4FFF;fontColor=#FFFFFF;strokeColor=none;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="1155" y="150" width="90" height="24" as="geometry" />
        </mxCell>

        <mxCell id="legendS3" value="S3 Resource" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7AA116;fontColor=#FFFFFF;strokeColor=none;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="1155" y="184" width="90" height="24" as="geometry" />
        </mxCell>

        <mxCell id="legendIam" value="IAM / Policy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DD344C;fontColor=#FFFFFF;strokeColor=none;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="1155" y="218" width="90" height="24" as="geometry" />
        </mxCell>

        <mxCell id="legendTf" value="Terraform (generic icon)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5C4EE5;fontColor=#FFFFFF;strokeColor=none;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="1155" y="252" width="150" height="24" as="geometry" />
        </mxCell>

        <mxCell id="legendDashed" value="Dashed = Terraform-managed relationship" style="text;html=1;fontSize=9;align=left;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1155" y="286" width="200" height="20" as="geometry" />
        </mxCell>

        <!-- ============ Note ============ -->
        <mxCell id="note" value="Note: draw.io has no official Terraform icon set; the purple &quot;Terraform&quot; boxes are generic placeholders (HashiCorp brand color #5C4EE5) representing Terraform-managed resources/config, not an official HashiCorp stencil. All AWS shapes use the built-in mxgraph.aws4 stencil library." style="text;html=1;fontSize=10;fontStyle=2;align=left;fontColor=#666666;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="200" y="700" width="900" height="40" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
